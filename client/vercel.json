{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://safereport-app.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://safereport-app.onrender.com/uploads/:path*"
    },
    {
      "source": "/((?!api|uploads).*项目*)",
      "destination": "/index.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
