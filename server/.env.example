# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/gbv_platform

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=8h

# ─── Uploads ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ─── Rate limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── CORS ─────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:5173
